[gd_scene load_steps=2 format=3]

[ext_resource type="Script" path="res://scenes/pages/result/result_page.gd" id="1_result"]

[node name="ResultPage" type="Control"]
layout_mode = 3
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
script = ExtResource("1_result")

[node name="MarginContainer" type="MarginContainer" parent="."]
layout_mode = 1
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
offset_left = 120.0
offset_top = 80.0
offset_right = -120.0
offset_bottom = -80.0
grow_horizontal = 2
grow_vertical = 2
theme_override_constants/margin_left = 16
theme_override_constants/margin_top = 16
theme_override_constants/margin_right = 16
theme_override_constants/margin_bottom = 16

[node name="Content" type="VBoxContainer" parent="MarginContainer"]
layout_mode = 2
theme_override_constants/separation = 18
alignment = 1

[node name="TitleLabel" type="Label" parent="MarginContainer/Content"]
layout_mode = 2
text = "结算"
horizontal_alignment = 1

[node name="DescriptionLabel" type="Label" parent="MarginContainer/Content"]
layout_mode = 2
text = "-"
horizontal_alignment = 1
autowrap_mode = 3

[node name="BackToLevelSelectButton" type="Button" parent="MarginContainer/Content"]
custom_minimum_size = Vector2(220, 48)
layout_mode = 2
size_flags_horizontal = 4
text = "返回关卡选择"

[connection signal="pressed" from="MarginContainer/Content/BackToLevelSelectButton" to="." method="_on_back_to_level_select_button_pressed"]
